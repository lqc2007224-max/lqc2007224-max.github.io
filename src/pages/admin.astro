---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="写作后台">
  <div class="admin-shell">
    <section class="admin-hero">
      <div>
        <p class="eyebrow">Local Studio</p>
        <h1>写博客，发布到网站和 Obsidian。</h1>
        <p>
          现在后台会把文章写入 SQLite 数据库，也会同步生成博客 Markdown。以后部署到服务器后，
          这里就是你真正在线管理文章、评论和草稿的入口。
        </p>
      </div>
      <aside>
        <strong data-admin-state>等待编辑</strong>
        <label class="admin-token">
          <span>后台 Token</span>
          <input data-admin-token type="password" placeholder="本地可留空，服务器必填" />
        </label>
      </aside>
    </section>

    <section class="admin-grid">
      <form class="admin-panel admin-editor" data-admin-form>
        <div class="admin-toolbar">
          <button class="admin-tool-button" type="button" data-new-post>新文章</button>
          <label class="admin-import">
            <span>导入 Word 编辑</span>
            <input type="file" accept=".docx" data-docx-input />
          </label>
          <label class="admin-import admin-import-primary">
            <span>上传 Word 并发布</span>
            <input type="file" accept=".docx" data-docx-publish-input />
          </label>
          <label class="admin-import">
            <span>插入图片</span>
            <input type="file" accept="image/*" multiple data-image-input />
          </label>
          <label class="admin-import">
            <span>封面图</span>
            <input type="file" accept="image/*" data-cover-input />
          </label>
        </div>

        <div class="admin-fields">
          <label>
            <span>标题</span>
            <input name="title" data-title required placeholder="写一个清楚的标题" />
          </label>
          <label>
            <span>摘要</span>
            <input name="summary" data-summary placeholder="一句话说明这篇文章在讲什么" />
          </label>
          <label>
            <span>分类</span>
            <select name="category" data-category>
              <option>研究日志</option>
              <option>论文</option>
              <option>学习笔记</option>
              <option>项目复盘</option>
              <option>日记</option>
              <option>想法</option>
            </select>
          </label>
          <label>
            <span>标签</span>
            <input name="tags" data-tags placeholder="AI, 论文, 产品" />
          </label>
          <label>
            <span>Obsidian 同步目录</span>
            <input
              name="obsidianPath"
              data-obsidian-path
              placeholder="留空默认同步到桌面 obsidian/Blog"
            />
          </label>
          <label>
            <span>状态</span>
            <select name="status" data-status>
              <option value="published">发布</option>
              <option value="draft">草稿</option>
            </select>
          </label>
        </div>

        <label class="admin-body">
          <span>正文 Markdown</span>
          <textarea data-body name="body" placeholder="# 小标题&#10;&#10;从这里开始写正文。" required></textarea>
        </label>

        <div class="admin-actions">
          <button class="button" type="submit">发布并重建</button>
          <button class="button secondary" type="button" data-save-draft>保存本地草稿</button>
          <button class="button secondary" type="button" data-clear>清空</button>
        </div>
      </form>

      <aside class="admin-side">
        <section class="admin-panel admin-library">
          <div class="admin-side-head">
            <div>
              <p class="eyebrow">Database</p>
              <h2>文章库</h2>
            </div>
            <button type="button" data-refresh-posts>刷新</button>
          </div>
          <div class="admin-post-list" data-post-list>
            <p class="admin-muted">正在读取数据库文章。</p>
          </div>
        </section>

        <section class="admin-panel admin-preview">
          <div class="admin-preview-head">
            <span data-preview-category>研究日志</span>
            <time data-preview-date></time>
          </div>
          <h2 data-preview-title>还没有标题</h2>
          <p data-preview-summary>摘要会显示在这里。</p>
          <div class="admin-preview-tags" data-preview-tags></div>
          <div class="admin-preview-body" data-preview-body></div>
        </section>
      </aside>
    </section>
  </div>

  <script>
    const form = document.querySelector("[data-admin-form]");
    const state = document.querySelector("[data-admin-state]");
    const tokenInput = document.querySelector("[data-admin-token]");
    const titleInput = document.querySelector("[data-title]");
    const summaryInput = document.querySelector("[data-summary]");
    const categoryInput = document.querySelector("[data-category]");
    const tagsInput = document.querySelector("[data-tags]");
    const statusInput = document.querySelector("[data-status]");
    const bodyInput = document.querySelector("[data-body]");
    const obsidianInput = document.querySelector("[data-obsidian-path]");
    const docxInput = document.querySelector("[data-docx-input]");
    const docxPublishInput = document.querySelector("[data-docx-publish-input]");
    const imageInput = document.querySelector("[data-image-input]");
    const coverInput = document.querySelector("[data-cover-input]");
    const saveDraftButton = document.querySelector("[data-save-draft]");
    const clearButton = document.querySelector("[data-clear]");
    const newPostButton = document.querySelector("[data-new-post]");
    const refreshPostsButton = document.querySelector("[data-refresh-posts]");
    const postList = document.querySelector("[data-post-list]");
    const previewTitle = document.querySelector("[data-preview-title]");
    const previewSummary = document.querySelector("[data-preview-summary]");
    const previewCategory = document.querySelector("[data-preview-category]");
    const previewDate = document.querySelector("[data-preview-date]");
    const previewTags = document.querySelector("[data-preview-tags]");
    const previewBody = document.querySelector("[data-preview-body]");
    const assets = [];
    let coverAsset = null;
    let currentSlug = "";
    let currentCoverPath = "";
    const isLocalWritingHost = ["localhost", "127.0.0.1"].includes(window.location.hostname);
    const isGithubPages = window.location.hostname.endsWith("github.io");

    const setState = (value) => {
      if (state) state.textContent = value;
    };

    const getAdminToken = () => {
      if (tokenInput instanceof HTMLInputElement) return tokenInput.value.trim();
      return localStorage.getItem("blog-admin-token") || "";
    };

    const rememberAdminToken = () => {
      const value = getAdminToken();
      if (value) localStorage.setItem("blog-admin-token", value);
      else localStorage.removeItem("blog-admin-token");
    };

    const requireBackendApi = () => {
      if (!isGithubPages) return true;
      setState("GitHub Pages 不能写入数据库");
      window.alert("当前 GitHub Pages 只能静态预览。要发布、编辑、删除和保存数据库，请打开本地后台或部署到服务器。");
      return false;
    };

    const requestJson = async (url, options = {}) => {
      const headers = { ...(options.headers || {}) };
      const token = getAdminToken();
      if (token) headers["X-Admin-Token"] = token;
      if (options.payload) headers["Content-Type"] = "application/json";
      const response = await fetch(url, {
        method: options.method || "GET",
        headers,
        body: options.payload ? JSON.stringify(options.payload) : undefined,
      });
      const text = await response.text();
      let result = {};
      try {
        result = text ? JSON.parse(text) : {};
      } catch {
        throw new Error("后台接口没有返回 JSON。请确认你打开的是本地后台服务，不是 GitHub Pages 静态页面。");
      }
      if (!response.ok) {
        throw new Error(result.error || "操作失败。");
      }
      return result;
    };

    const postJson = (url, payload) => requestJson(url, { method: "POST", payload });

    const slugify = (value) =>
      String(value || "untitled")
        .trim()
        .toLowerCase()
        .replace(/[^\p{L}\p{N}]+/gu, "-")
        .replace(/^-+|-+$/g, "") || "untitled";

    const fileToBase64 = (file) =>
      new Promise((resolve, reject) => {
        const reader = new FileReader();
        reader.onload = () => resolve(String(reader.result || ""));
        reader.onerror = reject;
        reader.readAsDataURL(file);
      });

    const decodeXml = (value) =>
      String(value || "")
        .replace(/&lt;/g, "<")
        .replace(/&gt;/g, ">")
        .replace(/&amp;/g, "&")
        .replace(/&quot;/g, '"')
        .replace(/&apos;/g, "'");

    const readUint16 = (view, offset) => view.getUint16(offset, true);
    const readUint32 = (view, offset) => view.getUint32(offset, true);

    const inflateRaw = async (bytes) => {
      if (!("DecompressionStream" in window)) {
        throw new Error("当前浏览器不支持静态解压 Word 文档，请改用本地后台服务。");
      }
      const stream = new Blob([bytes]).stream().pipeThrough(new DecompressionStream("deflate-raw"));
      return new Uint8Array(await new Response(stream).arrayBuffer());
    };

    const readZipEntry = async (buffer, entryName) => {
      const view = new DataView(buffer);
      const bytes = new Uint8Array(buffer);
      let endOffset = -1;
      for (let offset = bytes.length - 22; offset >= 0; offset -= 1) {
        if (readUint32(view, offset) === 0x06054b50) {
          endOffset = offset;
          break;
        }
      }
      if (endOffset < 0) throw new Error("没有找到 Word 文档目录。");

      const totalEntries = readUint16(view, endOffset + 10);
      let centralOffset = readUint32(view, endOffset + 16);
      const decoder = new TextDecoder("utf-8");

      for (let index = 0; index < totalEntries; index += 1) {
        if (readUint32(view, centralOffset) !== 0x02014b50) break;
        const method = readUint16(view, centralOffset + 10);
        const compressedSize = readUint32(view, centralOffset + 20);
        const fileNameLength = readUint16(view, centralOffset + 28);
        const extraLength = readUint16(view, centralOffset + 30);
        const commentLength = readUint16(view, centralOffset + 32);
        const localOffset = readUint32(view, centralOffset + 42);
        const name = decoder.decode(bytes.slice(centralOffset + 46, centralOffset + 46 + fileNameLength));

        if (name === entryName) {
          if (readUint32(view, localOffset) !== 0x04034b50) throw new Error("Word 文档局部目录损坏。");
          const localNameLength = readUint16(view, localOffset + 26);
          const localExtraLength = readUint16(view, localOffset + 28);
          const dataStart = localOffset + 30 + localNameLength + localExtraLength;
          const compressed = bytes.slice(dataStart, dataStart + compressedSize);
          if (method === 0) return compressed;
          if (method === 8) return inflateRaw(compressed);
          throw new Error("暂不支持这个 Word 文档的压缩格式。");
        }

        centralOffset += 46 + fileNameLength + extraLength + commentLength;
      }

      throw new Error("Word 文档里没有找到正文。");
    };

    const docxXmlToMarkdown = (xml) => {
      const paragraphs = Array.from(String(xml || "").matchAll(/<w:p(?:\s[^>]*)?>[\s\S]*?<\/w:p>/g)).map((match) => match[0]);
      const lines = [];
      for (const paragraph of paragraphs) {
        const text = decodeXml(
          Array.from(paragraph.matchAll(/<w:t(?:\s[^>]*)?>([\s\S]*?)<\/w:t>/g))
            .map((match) => match[1])
            .join(""),
        ).trim();
        if (!text) continue;
        const style = /<w:pStyle[^>]*w:val="([^"]+)"/.exec(paragraph)?.[1] || "";
        if (/Heading1|Title/i.test(style)) lines.push(`# ${text}`);
        else if (/Heading2/i.test(style)) lines.push(`## ${text}`);
        else if (/Heading3/i.test(style)) lines.push(`### ${text}`);
        else lines.push(text);
      }
      return lines.join("\n\n");
    };

    const importDocxInBrowser = async (file) => {
      const xmlBytes = await readZipEntry(await file.arrayBuffer(), "word/document.xml");
      const markdown = docxXmlToMarkdown(new TextDecoder("utf-8").decode(xmlBytes));
      if (!markdown.trim()) throw new Error("Word 文档导入成功，但没有提取到正文文字。");
      const firstParagraph = markdown.split(/\r?\n/).find((line) => line.trim() && !line.startsWith("#")) || "";
      return {
        title: file.name.replace(/\.docx$/i, ""),
        summary: firstParagraph.slice(0, 120),
        markdown,
      };
    };

    const importDocxFile = async (file) => {
      let result;
      if (!isGithubPages) {
        try {
          const dataUrl = await fileToBase64(file);
          result = await postJson("/api/admin/import-docx", { fileName: file.name, dataUrl });
        } catch {
          result = await importDocxInBrowser(file);
        }
      } else {
        result = await importDocxInBrowser(file);
      }
      return result;
    };

    const escapeHtml = (value) =>
      String(value).replace(/[&<>"']/g, (char) => ({
        "&": "&amp;",
        "<": "&lt;",
        ">": "&gt;",
        '"': "&quot;",
        "'": "&#039;",
      })[char]);

    const renderMarkdown = (markdown) => {
      const lines = String(markdown || "").split(/\r?\n/);
      let html = "";
      let paragraph = [];
      const flush = () => {
        if (!paragraph.length) return;
        html += `<p>${escapeHtml(paragraph.join(" "))}</p>`;
        paragraph = [];
      };
      for (const line of lines) {
        const trimmed = line.trim();
        if (!trimmed) {
          flush();
          continue;
        }
        const heading = /^(#{1,3})\s+(.+)$/.exec(trimmed);
        if (heading) {
          flush();
          html += `<h3>${escapeHtml(heading[2])}</h3>`;
          continue;
        }
        const image = /^!\[([^\]]*)\]\(([^)]+)\)$/.exec(trimmed);
        if (image) {
          flush();
          html += `<figure><img src="${image[2]}" alt="${escapeHtml(image[1])}" /><figcaption>${escapeHtml(image[1])}</figcaption></figure>`;
          continue;
        }
        paragraph.push(trimmed);
      }
      flush();
      return html || "<p>正文预览会显示在这里。</p>";
    };

    const renderPostList = (posts = []) => {
      if (!postList) return;
      postList.innerHTML = posts.length
        ? posts
            .map((post) => `
              <article class="admin-post-row ${post.slug === currentSlug ? "active" : ""}" data-post-slug="${escapeHtml(post.slug)}">
                <button type="button" data-edit-post="${escapeHtml(post.slug)}">
                  <span>${escapeHtml(post.category || "博客")} · ${escapeHtml(post.status === "draft" ? "草稿" : "已发布")}</span>
                  <strong>${escapeHtml(post.title || post.slug)}</strong>
                  <small>${escapeHtml((post.updatedAt || post.publishedAt || "").slice(0, 16).replace("T", " "))}</small>
                </button>
                <button class="danger" type="button" data-delete-post="${escapeHtml(post.slug)}">删除</button>
              </article>
            `)
            .join("")
        : `<div class="admin-empty">
            <strong>数据库里还没有文章</strong>
            <p>导入 Word 或直接写 Markdown，然后点击发布，第一篇文章会出现在这里。</p>
          </div>`;
    };

    const loadPosts = async () => {
      if (isGithubPages) {
        renderPostList([]);
        return;
      }
      try {
        const result = await requestJson("/api/admin/posts");
        renderPostList(result.posts || []);
        setState(`数据库文章：${(result.posts || []).length} 篇`);
      } catch (error) {
        if (postList) postList.innerHTML = `<p class="admin-muted">${escapeHtml(error instanceof Error ? error.message : "文章库读取失败")}</p>`;
      }
    };

    const applyPostToEditor = (post) => {
      currentSlug = post.slug || "";
      currentCoverPath = post.coverPath || "";
      assets.splice(0, assets.length);
      coverAsset = null;
      if (titleInput instanceof HTMLInputElement) titleInput.value = post.title || "";
      if (summaryInput instanceof HTMLInputElement) summaryInput.value = post.summary || "";
      if (categoryInput instanceof HTMLSelectElement) categoryInput.value = post.category || "研究日志";
      if (tagsInput instanceof HTMLInputElement) tagsInput.value = Array.isArray(post.tags) ? post.tags.join(", ") : "";
      if (statusInput instanceof HTMLSelectElement) statusInput.value = post.status || "published";
      if (bodyInput instanceof HTMLTextAreaElement) bodyInput.value = post.body || "";
      if (obsidianInput instanceof HTMLInputElement) obsidianInput.value = post.obsidianPath || "";
      setState(currentSlug ? `正在编辑：${currentSlug}` : "新文章");
      updatePreview();
    };

    const clearEditor = () => {
      form?.reset();
      if (bodyInput instanceof HTMLTextAreaElement) bodyInput.value = "";
      localStorage.removeItem("blog-admin-draft");
      assets.splice(0, assets.length);
      coverAsset = null;
      currentSlug = "";
      currentCoverPath = "";
      setState("新文章");
      updatePreview();
      loadPosts();
    };

    const buildPublishPayload = () => {
      if (!(titleInput instanceof HTMLInputElement) || !(bodyInput instanceof HTMLTextAreaElement)) return null;
      return {
        slug: currentSlug,
        title: titleInput.value,
        summary: summaryInput instanceof HTMLInputElement ? summaryInput.value : "",
        category: categoryInput instanceof HTMLSelectElement ? categoryInput.value : "研究日志",
        tags: tagsInput instanceof HTMLInputElement ? tagsInput.value.split(/[,，\s]+/).filter(Boolean) : [],
        status: statusInput instanceof HTMLSelectElement ? statusInput.value : "published",
        body: bodyInput.value,
        obsidianPath: obsidianInput instanceof HTMLInputElement ? obsidianInput.value : "",
        assets,
        cover: coverAsset,
        coverPath: currentCoverPath,
        rebuild: true,
      };
    };

    const updatePreview = () => {
      const tags = tagsInput instanceof HTMLInputElement ? tagsInput.value.split(/[,，\s]+/).filter(Boolean) : [];
      if (previewTitle) previewTitle.textContent = titleInput instanceof HTMLInputElement && titleInput.value ? titleInput.value : "还没有标题";
      if (previewSummary) previewSummary.textContent = summaryInput instanceof HTMLInputElement && summaryInput.value ? summaryInput.value : "摘要会显示在这里。";
      if (previewCategory) previewCategory.textContent = categoryInput instanceof HTMLSelectElement ? categoryInput.value : "研究日志";
      if (previewDate) previewDate.textContent = new Date().toLocaleDateString("zh-CN");
      if (previewTags) previewTags.innerHTML = tags.map((tag) => `<span>${escapeHtml(tag)}</span>`).join("");
      if (previewBody) previewBody.innerHTML = renderMarkdown(bodyInput instanceof HTMLTextAreaElement ? bodyInput.value : "");
    };

    const saveDraft = () => {
      if (!(titleInput instanceof HTMLInputElement) || !(bodyInput instanceof HTMLTextAreaElement)) return;
      localStorage.setItem("blog-admin-draft", JSON.stringify({
        title: titleInput.value,
        summary: summaryInput instanceof HTMLInputElement ? summaryInput.value : "",
        category: categoryInput instanceof HTMLSelectElement ? categoryInput.value : "研究日志",
        tags: tagsInput instanceof HTMLInputElement ? tagsInput.value : "",
        status: statusInput instanceof HTMLSelectElement ? statusInput.value : "published",
        body: bodyInput.value,
        obsidianPath: obsidianInput instanceof HTMLInputElement ? obsidianInput.value : "",
        slug: currentSlug,
        coverPath: currentCoverPath,
      }));
      setState("草稿已保存");
    };

    const loadDraft = () => {
      const raw = localStorage.getItem("blog-admin-draft");
      if (!raw) return;
      try {
        const draft = JSON.parse(raw);
        if (titleInput instanceof HTMLInputElement) titleInput.value = draft.title || "";
        if (summaryInput instanceof HTMLInputElement) summaryInput.value = draft.summary || "";
        if (categoryInput instanceof HTMLSelectElement) categoryInput.value = draft.category || "研究日志";
        if (tagsInput instanceof HTMLInputElement) tagsInput.value = draft.tags || "";
        if (statusInput instanceof HTMLSelectElement) statusInput.value = draft.status || "published";
        if (bodyInput instanceof HTMLTextAreaElement) bodyInput.value = draft.body || "";
        if (obsidianInput instanceof HTMLInputElement && draft.obsidianPath) obsidianInput.value = draft.obsidianPath;
        currentSlug = draft.slug || "";
        currentCoverPath = draft.coverPath || "";
      } catch {
        localStorage.removeItem("blog-admin-draft");
      }
    };

    docxInput?.addEventListener("change", async () => {
      const file = docxInput instanceof HTMLInputElement ? docxInput.files?.[0] : null;
      if (!file) return;
      setState("正在导入 Word");
      try {
        const result = await importDocxFile(file);
        if (titleInput instanceof HTMLInputElement && !titleInput.value) titleInput.value = result.title || file.name.replace(/\.docx$/i, "");
        if (bodyInput instanceof HTMLTextAreaElement) bodyInput.value = result.markdown || "";
        if (summaryInput instanceof HTMLInputElement && !summaryInput.value) summaryInput.value = result.summary || "";
        setState("Word 已导入");
        updatePreview();
      } catch (error) {
        setState(error instanceof Error ? error.message : "导入失败");
        return;
      }
    });

    docxPublishInput?.addEventListener("change", async () => {
      const file = docxPublishInput instanceof HTMLInputElement ? docxPublishInput.files?.[0] : null;
      if (!file) return;
      if (!requireBackendApi()) {
        if (docxPublishInput instanceof HTMLInputElement) docxPublishInput.value = "";
        return;
      }
      rememberAdminToken();
      setState("正在上传 Word 并发布");
      try {
        clearEditor();
        const result = await importDocxFile(file);
        if (titleInput instanceof HTMLInputElement) titleInput.value = result.title || file.name.replace(/\.docx$/i, "");
        if (bodyInput instanceof HTMLTextAreaElement) bodyInput.value = result.markdown || "";
        if (summaryInput instanceof HTMLInputElement) summaryInput.value = result.summary || "";
        if (statusInput instanceof HTMLSelectElement) statusInput.value = "published";
        updatePreview();

        const payload = buildPublishPayload();
        if (!payload) throw new Error("编辑器没有准备好，无法发布。");
        const publishResult = await postJson("/api/admin/publish", payload);
        currentSlug = publishResult.slug || currentSlug;
        currentCoverPath = publishResult.post?.coverPath || currentCoverPath;
        assets.splice(0, assets.length);
        coverAsset = null;
        localStorage.removeItem("blog-admin-draft");
        setState(`Word 已上传发布：${publishResult.href}`);
        await loadPosts();
      } catch (error) {
        setState(error instanceof Error ? error.message : "Word 上传发布失败");
      } finally {
        if (docxPublishInput instanceof HTMLInputElement) docxPublishInput.value = "";
      }
    });

    imageInput?.addEventListener("change", async () => {
      if (!(imageInput instanceof HTMLInputElement) || !(bodyInput instanceof HTMLTextAreaElement)) return;
      const title = titleInput instanceof HTMLInputElement ? titleInput.value : "untitled";
      const slug = slugify(title);
      for (const file of Array.from(imageInput.files || [])) {
        const dataUrl = await fileToBase64(file);
        assets.push({ name: file.name, dataUrl });
        bodyInput.value += `\n\n![${file.name}](/assets/blog/${slug}/${file.name})\n`;
      }
      imageInput.value = "";
      setState("图片已插入");
      updatePreview();
    });

    coverInput?.addEventListener("change", async () => {
      const file = coverInput instanceof HTMLInputElement ? coverInput.files?.[0] : null;
      if (!file) return;
      coverAsset = { name: file.name, dataUrl: await fileToBase64(file) };
      setState("封面图已选择");
    });

    form?.addEventListener("input", updatePreview);
    saveDraftButton?.addEventListener("click", saveDraft);
    clearButton?.addEventListener("click", clearEditor);
    newPostButton?.addEventListener("click", clearEditor);
    refreshPostsButton?.addEventListener("click", loadPosts);
    tokenInput?.addEventListener("change", () => {
      rememberAdminToken();
      loadPosts();
    });

    postList?.addEventListener("click", async (event) => {
      const editButton = event.target instanceof Element ? event.target.closest("[data-edit-post]") : null;
      const deleteButton = event.target instanceof Element ? event.target.closest("[data-delete-post]") : null;

      if (editButton instanceof HTMLButtonElement) {
        const slug = editButton.dataset.editPost || "";
        if (!slug) return;
        setState("正在读取文章");
        try {
          const result = await requestJson(`/api/admin/posts/${encodeURIComponent(slug)}`);
          applyPostToEditor(result.post);
          loadPosts();
        } catch (error) {
          setState(error instanceof Error ? error.message : "读取失败");
        }
      }

      if (deleteButton instanceof HTMLButtonElement) {
        const slug = deleteButton.dataset.deletePost || "";
        if (!slug || !window.confirm(`确定删除 ${slug} 吗？这会同步删除生成的博客页面。`)) return;
        setState("正在删除文章");
        try {
          await requestJson(`/api/admin/posts/${encodeURIComponent(slug)}`, { method: "DELETE" });
          if (currentSlug === slug) clearEditor();
          else await loadPosts();
          setState("文章已删除");
        } catch (error) {
          setState(error instanceof Error ? error.message : "删除失败");
        }
      }
    });

    form?.addEventListener("submit", async (event) => {
      event.preventDefault();
      if (!(titleInput instanceof HTMLInputElement) || !(bodyInput instanceof HTMLTextAreaElement)) return;
      if (!requireBackendApi()) return;
      rememberAdminToken();
      setState("正在发布");
      const payload = buildPublishPayload();
      if (!payload) return;
      let result;
      try {
        result = await postJson("/api/admin/publish", payload);
      } catch (error) {
        setState(error instanceof Error ? error.message : "发布失败");
        return;
      }
      localStorage.removeItem("blog-admin-draft");
      currentSlug = result.slug || currentSlug;
      currentCoverPath = result.post?.coverPath || currentCoverPath;
      assets.splice(0, assets.length);
      coverAsset = null;
      setState(`已发布：${result.href}`);
      loadPosts();
    });

    if (tokenInput instanceof HTMLInputElement) tokenInput.value = localStorage.getItem("blog-admin-token") || "";
    loadDraft();
    updatePreview();
    if (!isLocalWritingHost) {
      setState(isGithubPages ? "GitHub Pages：可导入和写草稿" : "正在连接后台数据库");
    }
    loadPosts();
  </script>
</BaseLayout>
