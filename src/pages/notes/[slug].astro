---
import DiscussionBox from "../../components/DiscussionBox.astro";
import { notes } from "../../data/site";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { slugify } from "../../utils/slug";

export function getStaticPaths() {
  return notes.map((note) => ({
    params: { slug: slugify(note.title) },
    props: { note },
  }));
}

const { note } = Astro.props;
const noteIndex = notes.findIndex((item) => item.title === note.title);
const coverClasses = ["cover-gold", "cover-teal", "cover-paper", "cover-cyan"];
const coverClass = coverClasses[Math.max(noteIndex, 0) % coverClasses.length];
const tocItems = [
  { id: "lead", label: "现场" },
  ...note.sections.map((section, index) => ({ id: `note-${index}`, label: section.title })),
  { id: "discussion", label: "讨论" },
];
---

<BaseLayout title={note.title} description={note.summary}>
  <div class="reading-progress" data-reading-progress></div>
  <div class="post-page diary-post">
    <a class="post-back-link" href="/notes/">返回笔记</a>

    <article class={`post-hero ${coverClass}`}>
      <div class="post-hero-content">
        <span class="post-category">Learning Note</span>
        <h1>{note.title}</h1>
        <p>{note.summary}</p>
        <div class="post-meta">
          <span>{note.date}</span>
          <span>{note.type}</span>
          <span>{note.status}</span>
        </div>
      </div>
    </article>

    <section class="post-layout">
      <article class="post-prose">
        <p id="lead" class="post-lead">{note.lead}</p>

        {
          note.sections.map((section, index) => (
            <section id={`note-${index}`}>
              <p class="section-kicker">Note</p>
              <h2>{section.title}</h2>
              <p>{section.body}</p>
              <ul>
                {section.items.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            </section>
          ))
        }
      </article>

      <aside class="toc-sidebar">
        <div class="toc-sticky">
          <p>Contents</p>
          <nav aria-label="笔记目录">
            {tocItems.map((item) => <a href={`#${item.id}`}>{item.label}</a>)}
          </nav>
          <details class="toc-details" open>
            <summary>当前动作</summary>
            <p>{note.action}</p>
          </details>
          <details class="toc-details">
            <summary>来源</summary>
            <p>{note.source}</p>
          </details>
        </div>
      </aside>
    </section>

    <section id="discussion" class="diary-discussion-shell">
      <DiscussionBox
        storageKey={`discussion-note-${slugify(note.title)}`}
        title="一起补充这条学习记录"
        intro="这里更适合放学习资料、经验提醒、踩坑记录和后续可以继续讨论的问题。"
        labels={["学习资料", "经验补充", "问题讨论", "路线建议"]}
        placeholder="比如：你推荐哪份资料？这条学习路线哪里容易踩坑？还有什么问题值得继续追？"
      />
    </section>
  </div>

  <script>
    const progress = document.querySelector("[data-reading-progress]");
    const updateProgress = () => {
      if (!(progress instanceof HTMLElement)) return;
      const max = document.documentElement.scrollHeight - window.innerHeight;
      const value = max > 0 ? window.scrollY / max : 0;
      progress.style.transform = `scaleX(${Math.min(1, Math.max(0, value))})`;
    };
    updateProgress();
    document.addEventListener("scroll", updateProgress, { passive: true });
  </script>
</BaseLayout>
