---
import BaseLayout from "../layouts/BaseLayout.astro";
import { profile } from "../data/site";

const github = profile.socials.find((item) => item.label === "GitHub");
const douyin = profile.socials.find((item) => item.label === "Douyin");
const qq = profile.contactQrs.find((item) => item.label === "QQ");
const wechat = profile.contactQrs.find((item) => item.label === "WeChat");
---

<BaseLayout title="联系">
  <div class="page-shell">
    <section class="section-header">
      <p class="eyebrow">Contact</p>
      <h1>联系褚落</h1>
      <p>如果你对 AI、项目、论文或学习路线感兴趣，可以通过下面的入口找到我。</p>
    </section>

    <section class="contact-grid">
      <div class="panel contact-panel-main">
        <div class="contact-signal" aria-hidden="true"></div>
        <div class="contact-launchpad">
          <a class="contact-launch-card contact-launch-card-github" href={github?.href} target="_blank" rel="noreferrer">
            <div class="launch-card-top">
              <span class="platform-mark platform-mark-github">
                <img src="/assets/contact/github-mark.svg" alt="" width="58" height="58" />
              </span>
              <span class="launch-label">Code</span>
            </div>
            <div>
              <strong>GitHub</strong>
              <small>{github?.value}</small>
            </div>
            <em>打开主页 <span>→</span></em>
          </a>

          <a class="contact-launch-card contact-launch-card-douyin" href={douyin?.href} target="_blank" rel="noreferrer">
            <div class="launch-card-top">
              <span class="platform-mark platform-mark-douyin">
                <img src="/assets/contact/douyin-mark.svg" alt="" width="58" height="58" />
              </span>
              <span class="launch-label">Video</span>
            </div>
            <div>
              <strong>抖音</strong>
              <small>点击跳转个人主页</small>
            </div>
            <em>打开主页 <span>→</span></em>
          </a>
        </div>

        <div class="contact-list">
          <article class="contact-line">
            <div class="contact-identity">
              <span class="platform-mark platform-mark-small platform-mark-qq">
                <img src="/assets/contact/qq-mark.svg" alt="" width="46" height="46" />
              </span>
              <div>
                <span class="contact-kicker">QQ</span>
                <strong class="contact-title-link">{qq?.copy}</strong>
                <p>可以复制号码，或在下方放大二维码扫码添加。</p>
              </div>
            </div>
            <div class="contact-actions">
              <button class="copy-button" type="button" data-copy-value={qq?.copy}>复制</button>
            </div>
          </article>

          <article class="contact-line">
            <div class="contact-identity">
              <span class="platform-mark platform-mark-small platform-mark-wechat">
                <img src="/assets/contact/wechat-mark.svg" alt="" width="46" height="46" />
              </span>
              <div>
                <span class="contact-kicker">WeChat</span>
                <strong class="contact-title-link">微信扫码添加</strong>
                <p>点击二维码可以放大查看，适合手机扫码。</p>
              </div>
            </div>
            <div class="contact-actions">
              <button class="copy-button" type="button" data-copy-value="请扫描微信二维码添加">复制说明</button>
            </div>
          </article>
        </div>

        <div class="qr-grid">
          {[qq, wechat].filter(Boolean).map((qr) => (
            <figure class="qr-card">
              <button
                class="qr-zoom"
                type="button"
                data-qr-open
                data-qr-src={qr.src}
                data-qr-title={qr.caption}
                aria-label={`放大${qr.label}二维码`}
              >
                <img src={qr.src} alt={qr.caption} width="320" height="320" />
              </button>
              <figcaption>
                <span>{qr.label}</span>
                <p>{qr.caption}</p>
              </figcaption>
              <button class="copy-button" type="button" data-copy-value={qr.copy}>复制账号</button>
            </figure>
          ))}
        </div>
      </div>

      <aside class="panel email-panel">
        <p class="eyebrow">Email</p>
        <h2>写信给我</h2>
        <p>邮箱单独放在这里，方便复制后用你自己的邮箱客户端发送。</p>
        <div class="email-tags">
          <span>AI 交流</span>
          <span>项目合作</span>
          <span>高中生咨询</span>
          <span>学习路线</span>
        </div>

        <div class="email-card">
          <span>Personal email</span>
          <strong>{profile.email}</strong>
          <div class="email-card-actions">
            <button class="copy-button email-copy-button" type="button" data-copy-value={profile.email}>复制邮箱</button>
            <small>复制后用自己的邮箱发送即可。</small>
          </div>
        </div>

        <div class="email-letter">
          <p>欢迎各位 AI 兴趣爱好者、大佬等来信。褚落也很希望可以与大家进行交流与学习，当然也可以进行合作。</p>
          <p>如果是迷茫的高中生，或者对大学生活有向往的高中生，也可以发邮箱给我。我都会认真看，也会尽量回信。</p>
          <p>欢迎大家发邮箱 dd 我，我一定会回。没回就是忙，或者你的邮件没有发过来，可以多发几次，或者加我微信。</p>
        </div>

        <div class="email-response-note">
          <span>Reply note</span>
          <strong>如果你希望我回复到某个邮箱，请在正文里再写一遍你的邮箱地址。</strong>
        </div>
      </aside>
    </section>
  </div>

  <div class="qr-modal" data-qr-modal aria-hidden="true">
    <button class="qr-modal-backdrop" type="button" data-qr-close aria-label="关闭二维码弹窗"></button>
    <figure class="qr-modal-panel">
      <button class="qr-modal-close" type="button" data-qr-close aria-label="关闭">×</button>
      <img data-qr-modal-img src="/assets/contact/qq-qr.jpg" alt="二维码放大图" width="560" height="560" />
      <figcaption data-qr-modal-title>二维码</figcaption>
      <div class="qr-modal-actions">
        <button class="copy-button" type="button" data-qr-copy>复制账号</button>
      </div>
    </figure>
  </div>

  <div class="copy-toast" data-copy-toast>已复制</div>

  <script>
    const toast = document.querySelector("[data-copy-toast]");
    let toastTimer;

    const showToast = (text = "已复制") => {
      if (!(toast instanceof HTMLElement)) return;
      toast.textContent = text;
      toast.classList.add("is-visible");
      window.clearTimeout(toastTimer);
      toastTimer = window.setTimeout(() => toast.classList.remove("is-visible"), 1300);
    };

    const copyText = async (value) => {
      try {
        if (navigator.clipboard && window.isSecureContext) {
          await navigator.clipboard.writeText(value);
          return true;
        }
      } catch {
        // Fall through to textarea copy.
      }
      const textarea = document.createElement("textarea");
      textarea.value = value;
      textarea.setAttribute("readonly", "");
      textarea.style.position = "fixed";
      textarea.style.left = "-9999px";
      document.body.append(textarea);
      textarea.select();
      const success = document.execCommand("copy");
      textarea.remove();
      return success;
    };

    document.querySelectorAll("[data-copy-value]").forEach((button) => {
      button.addEventListener("click", async () => {
        const value = button.getAttribute("data-copy-value") || "";
        const success = await copyText(value);
        showToast(success ? "已复制" : "复制失败");
      });
    });

    const modal = document.querySelector("[data-qr-modal]");
    const modalImg = document.querySelector("[data-qr-modal-img]");
    const modalTitle = document.querySelector("[data-qr-modal-title]");
    const modalCopy = document.querySelector("[data-qr-copy]");
    let activeQrCopy = "";

    document.querySelectorAll("[data-qr-open]").forEach((button) => {
      button.addEventListener("click", () => {
        if (!(modal instanceof HTMLElement) || !(modalImg instanceof HTMLImageElement)) return;
        const src = button.getAttribute("data-qr-src") || "";
        const title = button.getAttribute("data-qr-title") || "二维码";
        activeQrCopy = button.closest(".qr-card")?.querySelector("[data-copy-value]")?.getAttribute("data-copy-value") || "";
        modalImg.src = src;
        modalImg.alt = title;
        if (modalTitle) modalTitle.textContent = title;
        modal.classList.add("is-open");
        modal.setAttribute("aria-hidden", "false");
      });
    });

    document.querySelectorAll("[data-qr-close]").forEach((button) => {
      button.addEventListener("click", () => {
        if (!(modal instanceof HTMLElement)) return;
        modal.classList.remove("is-open");
        modal.setAttribute("aria-hidden", "true");
      });
    });

    modalCopy?.addEventListener("click", async () => {
      const success = await copyText(activeQrCopy);
      showToast(success ? "已复制" : "复制失败");
    });

    window.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && modal instanceof HTMLElement) {
        modal.classList.remove("is-open");
        modal.setAttribute("aria-hidden", "true");
      }
    });
  </script>
</BaseLayout>
